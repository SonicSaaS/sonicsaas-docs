# Force Windows platform for native binary resolution.
#
# Problem: Claude Code (and Git Bash / MINGW64 on Windows) makes npm report
# os=linux, so npm installs Linux native binaries (.node files) instead of
# Windows ones. Node.js actually runs on Windows and crashes at runtime.
#
# Fix: Force os=win32 here. CI overrides this via npm_config_os=linux env
# vars — see .github/workflows/deploy.yml.
os=win32
cpu=x64
